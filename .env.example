# Aetheris Enterprise Analytics - Root Environment Template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── PostgreSQL Database Configuration ──
POSTGRES_USER=aetheris_admin
POSTGRES_PASSWORD=SecretPGPass2026!
POSTGRES_DB=aetheris_analytics

# ── Backend Security Configuration ──
# SECRET_KEY must be a cryptographically secure random string of at least 32 characters in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=super-secret-aetheris-key-2026-indigo-glow-987654321

# ── SAP Integration Mode ──
USE_MOCK_SAP=True
