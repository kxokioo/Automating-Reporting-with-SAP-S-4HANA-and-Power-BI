# Aetheris Frontend - Environment Template
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Backend API base URL
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Power BI Embedded (Azure AD credentials)
VITE_POWERBI_WORKSPACE_ID=<your-workspace-id>
VITE_POWERBI_REPORT_ID=<your-report-id>
# VITE_AZURE_AD_CLIENT_ID=<your-azure-app-registration-client-id>
# VITE_AZURE_AD_TENANT_ID=<your-azure-tenant-id>
